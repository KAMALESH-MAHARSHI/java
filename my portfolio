<style>
  :root{
    --bg: #0E1512;
    --bg-panel: #131C18;
    --board: #16211C;
    --trace: #3F5C4E;
    --trace-bright: #5FD9A4;
    --copper: #D98E4A;
    --ink: #E9E4D6;
    --ink-dim: #9FAFA6;
    --ink-faint: #6C7A72;
    --danger: #E0704F;
    --radius: 3px;
  }
  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    margin:0;
    background:var(--bg);
    color:var(--ink);
    font-family:'IBM Plex Sans', sans-serif;
    font-size:16px;
    line-height:1.7;
  }
  ::selection{ background:var(--trace-bright); color:#0E1512; }
  a{ color:var(--trace-bright); text-decoration:none; }
  a:hover{ text-decoration:underline; }
  .mono{ font-family:'JetBrains Mono', monospace; }
  .wrap{
    max-width:960px;
    margin:0 auto;
    padding:0 32px;
  }
  .board-bg{
    background-image:
      linear-gradient(var(--trace) 1px, transparent 1px),
      linear-gradient(90deg, var(--trace) 1px, transparent 1px);
    background-size: 42px 42px;
    background-position: -1px -1px;
    opacity:0.08;
    position:fixed;
    inset:0;
    pointer-events:none;
    z-index:0;
  }
  header.hero{
    position:relative;
    padding:100px 0 70px;
    border-bottom:1px solid var(--trace);
    overflow:hidden;
  }
  .eyebrow{
    font-family:'JetBrains Mono', monospace;
    font-size:13px;
    letter-spacing:0.12em;
    color:var(--trace-bright);
    text-transform:uppercase;
    margin:0 0 18px;
    display:flex;
    align-items:center;
    gap:10px;
  }
  .eyebrow::before{
    content:"";
    width:8px; height:8px;
    background:var(--trace-bright);
    border-radius:50%;
    box-shadow:0 0 8px var(--trace-bright);
    animation:pulse 2s infinite ease-in-out;
  }
  @keyframes pulse{
    0%,100%{opacity:1;}
    50%{opacity:0.35;}
  }
  h1.name{
    font-family:'JetBrains Mono', monospace;
    font-size:44px;
    font-weight:700;
    margin:0 0 14px;
    line-height:1.15;
    letter-spacing:-0.01em;
  }
  .role-line{
    font-size:19px;
    color:var(--ink-dim);
    margin:0 0 34px;
    max-width:560px;
  }
  .contact-row{
    display:flex;
    flex-wrap:wrap;
    gap:22px;
    font-family:'JetBrains Mono', monospace;
    font-size:14px;
  }
  .contact-row a{ color:var(--ink); }
  .contact-row a:hover{ color:var(--trace-bright); }
  .contact-row span.sep{ color:var(--ink-faint); }

  nav.trace-nav{
    position:sticky;
    top:0;
    z-index:10;
    background:rgba(14,21,18,0.92);
    backdrop-filter:blur(6px);
    border-bottom:1px solid var(--trace);
  }
  nav.trace-nav .wrap{
    display:flex;
    gap:28px;
    padding:16px 32px;
    overflow-x:auto;
  }
  nav.trace-nav a{
    font-family:'JetBrains Mono', monospace;
    font-size:13px;
    color:var(--ink-dim);
    white-space:nowrap;
    letter-spacing:0.03em;
  }
  nav.trace-nav a:hover{ color:var(--trace-bright); text-decoration:none; }

  section{ padding:64px 0; border-bottom:1px solid var(--trace); position:relative; z-index:1;}
  section:last-of-type{ border-bottom:none; }

  .section-head{
    display:flex;
    align-items:baseline;
    gap:16px;
    margin-bottom:36px;
  }
  .section-num{
    font-family:'JetBrains Mono', monospace;
    color:var(--copper);
    font-size:14px;
  }
  h2{
    font-family:'JetBrains Mono', monospace;
    font-size:24px;
    font-weight:700;
    margin:0;
    letter-spacing:-0.01em;
  }

  .about-grid{
    display:grid;
    grid-template-columns:1.3fr 1fr;
    gap:48px;
  }
  .about-text p{ color:var(--ink-dim); margin:0 0 16px; }
  .signal-box{
    background:var(--board);
    border:1px solid var(--trace);
    border-radius:var(--radius);
    padding:22px 24px;
  }
  .signal-box h3{
    font-family:'JetBrains Mono', monospace;
    font-size:13px;
    text-transform:uppercase;
    letter-spacing:0.08em;
    color:var(--trace-bright);
    margin:0 0 14px;
  }
  .signal-box ul{ margin:0; padding-left:18px; color:var(--ink-dim); font-size:14px; }
  .signal-box li{ margin-bottom:8px; }

  .skills-grid{
    display:grid;
    grid-template-columns:repeat(3, 1fr);
    gap:20px;
  }
  .skill-card{
    background:var(--board);
    border:1px solid var(--trace);
    border-radius:var(--radius);
    padding:20px;
  }
  .skill-card h3{
    font-family:'JetBrains Mono', monospace;
    font-size:13px;
    color:var(--copper);
    text-transform:uppercase;
    letter-spacing:0.06em;
    margin:0 0 12px;
  }
  .chip-row{ display:flex; flex-wrap:wrap; gap:8px; }
  .chip{
    font-family:'JetBrains Mono', monospace;
    font-size:12px;
    color:var(--ink);
    border:1px solid var(--trace);
    border-radius:20px;
    padding:5px 12px;
    background:rgba(95,217,164,0.05);
  }

  .timeline{ position:relative; padding-left:28px; }
  .timeline::before{
    content:"";
    position:absolute;
    left:5px; top:6px; bottom:6px;
    width:1px;
    background:var(--trace);
  }
  .t-item{ position:relative; margin-bottom:40px; }
  .t-item:last-child{ margin-bottom:0; }
  .t-item::before{
    content:"";
    position:absolute;
    left:-28px; top:5px;
    width:11px; height:11px;
    border-radius:50%;
    background:var(--bg);
    border:2px solid var(--trace-bright);
  }
  .t-role{ font-family:'JetBrains Mono', monospace; font-size:16px; font-weight:700; margin:0 0 2px;}
  .t-org{ color:var(--copper); font-size:14px; margin:0 0 4px; }
  .t-date{ font-family:'JetBrains Mono', monospace; font-size:12px; color:var(--ink-faint); margin:0 0 12px; }
  .t-item ul{ margin:0; padding-left:18px; color:var(--ink-dim); font-size:14.5px; }
  .t-item li{ margin-bottom:6px; }

  .project-card{
    background:var(--board);
    border:1px solid var(--trace);
    border-radius:var(--radius);
    padding:28px;
    margin-bottom:24px;
  }
  .project-card.featured{
    border-color:var(--trace-bright);
    box-shadow:0 0 0 1px rgba(95,217,164,0.15);
  }
  .project-top{
    display:flex;
    justify-content:space-between;
    align-items:flex-start;
    gap:16px;
    margin-bottom:14px;
    flex-wrap:wrap;
  }
  .project-title{ font-family:'JetBrains Mono', monospace; font-size:18px; font-weight:700; margin:0; }
  .project-tag{
    font-family:'JetBrains Mono', monospace;
    font-size:11px;
    color:var(--bg);
    background:var(--trace-bright);
    padding:4px 10px;
    border-radius:20px;
    white-space:nowrap;
  }
  .project-meta{
    font-family:'JetBrains Mono', monospace;
    font-size:12px;
    color:var(--ink-faint);
    margin:0 0 14px;
  }
  .project-card ul{ margin:0 0 16px; padding-left:18px; color:var(--ink-dim); font-size:14.5px; }
  .project-card li{ margin-bottom:6px; }
  .stack-row{ display:flex; flex-wrap:wrap; gap:8px; }
  .stack-chip{
    font-family:'JetBrains Mono', monospace;
    font-size:11.5px;
    color:var(--ink-dim);
    border:1px solid var(--trace);
    padding:4px 10px;
    border-radius:var(--radius);
  }

  .cert-grid{
    display:grid;
    grid-template-columns:repeat(2, 1fr);
    gap:14px;
  }
  .cert-item{
    display:flex;
    justify-content:space-between;
    gap:12px;
    border:1px solid var(--trace);
    border-radius:var(--radius);
    padding:14px 18px;
    background:var(--board);
    font-size:14px;
  }
  .cert-item span.org{ color:var(--ink-faint); font-family:'JetBrains Mono', monospace; font-size:12px; white-space:nowrap; }

  footer{
    padding:70px 0 60px;
    text-align:center;
  }
  footer h2{ margin-bottom:14px; }
  footer p{ color:var(--ink-dim); max-width:480px; margin:0 auto 30px; }
  .cta-row{ display:flex; justify-content:center; gap:16px; flex-wrap:wrap; }
  .btn{
    font-family:'JetBrains Mono', monospace;
    font-size:14px;
    padding:12px 24px;
    border-radius:var(--radius);
    border:1px solid var(--trace-bright);
    color:var(--trace-bright);
    transition:all 0.15s ease;
  }
  .btn:hover{ background:var(--trace-bright); color:var(--bg); text-decoration:none; }
  .btn.solid{ background:var(--trace-bright); color:var(--bg); }
  .btn.solid:hover{ background:transparent; color:var(--trace-bright); }
  .foot-note{
    margin-top:50px;
    font-family:'JetBrains Mono', monospace;
    font-size:12px;
    color:var(--ink-faint);
  }

  @media(max-width:760px){
    .wrap{ padding:0 20px; }
    h1.name{ font-size:32px; }
    .about-grid{ grid-template-columns:1fr; }
    .skills-grid{ grid-template-columns:1fr 1fr; }
    .cert-grid{ grid-template-columns:1fr; }
    nav.trace-nav .wrap{ gap:18px; }
  }
  @media(max-width:520px){
    .skills-grid{ grid-template-columns:1fr; }
  }
  @media (prefers-reduced-motion: reduce){
    .eyebrow::before{ animation:none; }
  }
</style>
